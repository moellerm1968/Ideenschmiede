# GitHub Copilot SDK verwendet die Authentifizierung der GitHub Copilot CLI.
# Stelle sicher, dass die Copilot CLI installiert und authentifiziert ist:
#   gh extension install github/gh-copilot
#   gh auth login

COPILOT_MODEL=gpt-4o-mini

PORT=3000
CMO_INTERVAL_MS=300000
PM_INTERVAL_MS=120000
SPECIALIST_INTERVAL_MS=300000
